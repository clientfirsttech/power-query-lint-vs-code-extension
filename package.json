{
  "name": "power-query-lint",
  "displayName": "Power Query Lint",
  "description": "Visual Studio Code Extension for Power Query Lint with MCP server support",
  "version": "0.4.2",
  "publisher": "ClientFirstTechnologies",
  "icon": "images/icon.jpg",
  "engines": {
    "vscode": "^1.99.0"
  },
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "power-query",
    "power-bi",
    "lint",
    "mcp",
    "model-context-protocol"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatAgents": [
      {
        "path": "resources/agents/power-query-linter.md"
      },
      {
        "path": "resources/agents/power-query-tester.md"
      }
    ],
    "chatSkills": [
      {
        "path": "skills/pql-assert/SKILL.md"
      },
      {
        "path": "skills/dax-query-guidelines/SKILL.md"
      }
    ],
    "commands": [
      {
        "command": "powerquery-lint.lint",
        "title": "Power Query: Lint Document"
      },
      {
        "command": "powerquery-lint.lintWorkspace",
        "title": "Power Query: Lint Workspace"
      }
    ],
    "languages": [
      {
        "id": "powerquery",
        "aliases": [
          "Power Query",
          "powerquery"
        ],
        "extensions": [
          ".pq",
          ".pqm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Power Query Lint",
      "properties": {
        "powerQueryLint.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Power Query linting"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^10.0.1",
    "standard-version": "^9.5.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clientfirsttech/power-query-lint-vs-code-extension.git"
  },
  "license": "MIT"
}
