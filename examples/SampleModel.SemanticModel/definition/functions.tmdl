			VAR _ZeroCount = COUNTAX(ALLNOBLANKROW(columnRef), IF(columnRef = 0, 1, BLANK()))
			VAR _TotalCount = COUNTROWS(ALLNOBLANKROW(columnRef))
			VAR _Passed = _ZeroCount = 0
