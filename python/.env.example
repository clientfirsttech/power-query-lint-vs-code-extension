# pql-test environment variables
#
# Copy this file to .env and fill in the values, or set the variables
# directly in your CI/CD pipeline secrets.
#
# python-dotenv loads .env automatically when present.
# Never commit a .env file containing real credentials to source control.

# ---------------------------------------------------------------------------
# Remote Power BI Premium / Fabric XMLA endpoint
# ---------------------------------------------------------------------------

# Azure AD tenant GUID
PQL_TENANT_ID=

# Power BI workspace GUID
PQL_WORKSPACE_ID=

# Dataset / semantic model GUID
PQL_DATASET_ID=

# ---------------------------------------------------------------------------
# Service principal credentials (required for build-agent / RLS evaluation)
#
# Register an app in Azure AD and grant it the "Dataset.ReadWrite.All"
# (or "Dataset.Read.All") Power BI service permission.
# Add the service principal to the Power BI workspace as a Member or Admin.
# ---------------------------------------------------------------------------

# Application (client) ID of the service principal
PQL_CLIENT_ID=

# Client secret for the service principal
PQL_CLIENT_SECRET=
